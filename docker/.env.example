# Copy this file to docker/.env and fill in your values.

# Steam Game Server Login Token — required to list the server publicly.
# Get one at: https://steamcommunity.com/dev/managegameservers (App ID 730)
# Leave blank to run as a LAN/hidden server.
SRCDS_TOKEN=

# Server settings
CS2_SERVERNAME=CS2 Observability Dev
CS2_MAXPLAYERS=10
CS2_STARTMAP=de_dust2
CS2_GAMETYPE=0
CS2_GAMEMODE=1
CS2_RCONPW=changeme
CS2_PORT=27015

# Grafana
GRAFANA_PORT=3000
